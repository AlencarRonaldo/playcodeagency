{
  "framework": "nextjs",
  "buildCommand": "rm -rf .next node_modules/.cache && npm run build",
  "installCommand": "npm install",
  "regions": ["gru1"],
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.playcodeagency.xyz" }],
      "destination": "https://playcodeagency.xyz/:path",
      "permanent": true
    }
  ]
}